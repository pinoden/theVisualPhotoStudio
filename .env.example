# Copy this file to .env and fill in the values

# Flask
SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=development

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Email (Gmail example — use an App Password, not your main password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
STUDIO_EMAIL=studio@thevisualsphotostudio.com

# Square Payments
# Get these from https://developer.squareup.com/apps
SQUARE_ENVIRONMENT=sandbox
SQUARE_APPLICATION_ID=sandbox-sq0idb-XXXXXXXX
SQUARE_ACCESS_TOKEN=EAAAxxxxxxxxxxxxxxxxxx
SQUARE_LOCATION_ID=XXXXXXXXXXXXXXXX

# Booking settings
BUNDLE_DISCOUNT_PCT=10
DEPOSIT_PCT=30
SLOT_INCREMENT_MINUTES=30
